apiVersion: dataprepper.kaasops.io/v1alpha1
kind: DataPrepperPipeline
metadata:
  name: e2e-blast-b
  namespace: {{ .Namespace }}
spec:
  image: opensearchproject/data-prepper:2.10.0
  pipelines:
    - name: kafka-to-stdout
      source:
        kafka:
          bootstrapServers:
            - "{{ .BootstrapServers }}"
          topic: {{ .TopicB }}
          groupId: dp-e2e-blast-b
          encryptionType: none
      sink:
        - stdout: {}
  scaling:
    mode: manual
    fixedReplicas: 1
